# ─────────────────────────────────────────────────────────────
# TrafficVision AI — Environment Variables
# Copy this file to .env and fill in the actual values.
# .env is listed in .gitignore and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Async PostgreSQL connection string (asyncpg driver).
# For local Docker Compose use the service hostname "postgres".
# For production (Neon, Railway, Render) use the provider-issued URL.
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/trafficvision

# ── Storage Backend Selector ──────────────────────────────────
# Controls which object storage backend the application uses.
#   minio    — local dockerized MinIO (development default)
#   supabase — Supabase object storage (production)
STORAGE_BACKEND=minio

# ── MinIO (used when STORAGE_BACKEND=minio) ───────────────────
# Hostname (and optional port) of the MinIO instance.
# For Docker Compose: minio:9000
# For self-hosted production: your.minio.host:9000
MINIO_ENDPOINT=localhost:9000

# MinIO root / access credentials.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Name of the bucket that holds all traffic images.
MINIO_BUCKET=traffic-images

# Set to "true" when the MinIO endpoint is served over HTTPS.
MINIO_SECURE=false

# ── Supabase S3-compatible Storage (used when STORAGE_BACKEND=supabase) ──
# Option A — AWS-style variable names (matches what Render dashboard uses):
AWS_ENDPOINT_URL=https://your-project-ref.supabase.co/storage/v1/s3
AWS_ACCESS_KEY_ID=your-s3-access-key-id
AWS_SECRET_ACCESS_KEY=your-s3-secret-access-key
BUCKET_NAME=trafficvision-bucket

# Option B — explicit Supabase variable names (alternative):
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
# SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
# SUPABASE_BUCKET=trafficvision-bucket

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development default: Vite dev server.
# Production: your Vercel deployment URL, e.g. https://trafficvision.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── ML Models ─────────────────────────────────────────────────
# Directory (relative to the backend working directory) where .pt weights live.
# Docker Compose mounts ./trained_models into /app/trained_models.
MODEL_DIR=trained_models

# ── Application ───────────────────────────────────────────────
# "development" enables verbose error details in API responses.
# "production" suppresses internal details; only generic messages are returned.
APP_ENV=development

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
